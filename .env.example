# ── Supabase (client-side) ────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Shopify OAuth (from Shopify Partners dashboard) ───────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ── Supabase (server-side only — no VITE_ prefix) ────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── App URL ───────────────────────────────────────────────────────────────────
APP_URL=https://www.strmlive.com

# ── Sentry (error monitoring) ──────────────────────────────────────────────
VITE_SENTRY_DSN=

# ── Mixpanel (analytics) ──────────────────────────────────────────────────
VITE_MIXPANEL_TOKEN=

# ── Existing (contact form / email) ──────────────────────────────────────────
# SHEET_WEBHOOK_URL=
# NOTIFY_SMTP_USER=
# NOTIFY_SMTP_PASS=
# NOTIFY_SMTP_HOST=smtp.gmail.com
# NOTIFY_SMTP_PORT=587
